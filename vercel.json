{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|facebookcatalog|zalo|twitterbot|linkedinbot|whatsapp|telegrambot|viber|skypeuripreview|discordbot).*"
        }
      ],
      "destination": "/api/bot"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-digest",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron-stale",
      "schedule": "30 1 * * *"
    },
    {
      "path": "/api/cron-shoots",
      "schedule": "0 10 * * *"
    }
  ]
}
